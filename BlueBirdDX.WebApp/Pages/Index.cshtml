@page
@using BlueBirdDX.WebApp.Services
@using MongoDB.Driver
@using BlueBirdDX.Common.Account
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using MongoDB.Bson
@model IndexModel
@{
    ViewData["Title"] = "Home page";

    const string cookieName = "index-current-group";

    string? defaultGroupId = null;

    if (HttpContext.Request.Cookies.TryGetValue(cookieName, out string? groupCookie))
    {
        if (ObjectId.TryParse(groupCookie, out ObjectId groupId))
        {
            if (Model.AccountGroupCollection.AsQueryable().FirstOrDefault(g => g._id == groupId) != null)
            {
                defaultGroupId = groupCookie;
            }
        }
    }

    if (defaultGroupId == null)
    {
        defaultGroupId = Model.AccountGroupCollection.AsQueryable().FirstOrDefault()!._id.ToString();
        
        HttpContext.Response.Cookies.Append(cookieName, defaultGroupId, new CookieOptions()
        {
            Path = "/",
            Expires = DateTimeOffset.UtcNow.AddYears(2),
            IsEssential = true,
            SameSite = SameSiteMode.Strict,
        });
    }
}

<div class="text-end mb-3">
    <a class="btn btn-primary" href="/thread/new" role="button">New Thread</a>
    <a class="btn btn-success" href="#footer" role="button">⏬</a>
</div>

<select id="groupSelect" class="form-select mb-3">
    @foreach (AccountGroup group in Model.AccountGroupCollection.AsQueryable())
    {
        <option value="@group._id.ToString()">@group.Name</option>
    }
</select>

<table class="table">
    <thead>
    <tr>
        <th scope="col">Thread Name</th>
        <th scope="col">State</th>
        <th scope="col">Actions</th>
    </tr>
    </thead>
    <tbody>
    </tbody>
</table>

<div class="text-end mt-2">
    <a class="btn btn-primary" href="/thread/new" role="button">New Thread</a>
    <a class="btn btn-success" href="#header" role="button">⏫</a>
</div>

<!-- Deleting modal -->
<div id="deleting-modal" class="modal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Deleting Posts</h5>
            </div>
            <div class="modal-body">
                <p id="deleting-element">Please wait.</p>
            </div>
        </div>
    </div>
</div>

<!-- Delete result modal -->
<div id="delete-result-modal" class="modal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="delete-result-title" class="modal-title">Deleted</h5>
            </div>
            <div class="modal-body">
                <p id="delete-result-element">Finished.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- Error modal -->
<div id="error-modal" class="modal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Error</h5>
            </div>
            <div class="modal-body">
                <p id="error-element">An error occurred while fetching threads.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        function repopulateTable(response) {
            for (const thread of response) {
                let row = "<tr><td>" + thread.name + "</td><td>" + thread.state + "</td><td>";
                let actions = []
                
                if (thread.state === "Draft" || thread.state === "Enqueued") {
                    actions.push("<a href=\"/thread/" + thread.id + "/\">✏️ edit</a>");
                }

                actions.push("<a href=\"/thread/new?baseThreadId=" + thread.id + "\">📋 clone</a>");

                if (thread.state === "Sent") {
                    actions.push("<a href=\"#\" class=\"delete-posts-link\" data-thread-id=\"" + thread.id + "\">🗑️ delete</a>");
                }

                $("tbody").append("<tr><td>" + thread.name + "</td><td>" + thread.state + "</td><td>" + actions.join(", ") + "</td></tr>");
            }
        }

        function requestRepopulateTable() {
            const groupId = $("#groupSelect").val();
            
            $("tbody").empty();
            
            $.ajax({
                method: "GET",
                url: "/api/v1/group/" + groupId + "/threads"
            }).done(repopulateTable).fail(function () {
                $("#error-modal").modal("show");
            });
        }

        function showDeleteResult(title, message) {
            $("#delete-result-title").text(title);
            $("#delete-result-element").text(message);
            $("#delete-result-modal").modal("show");
            $("#deleting-modal").modal("hide");
        }

        $("tbody").on("click", ".delete-posts-link", function (event) {
            event.preventDefault();

            const threadId = $(this).data("thread-id");

            $("#deleting-modal").modal("show");

            $.ajax({
                method: "POST",
                url: "/api/v1/thread/" + threadId + "/delete"
            }).done(function () {
                showDeleteResult("Deleted", "The thread has been deleted.");
            }).fail(function (xhr) {
                let message = "Deletion failed.";

                if (xhr.responseJSON && xhr.responseJSON.detail) {
                    message = xhr.responseJSON.detail;
                } else if (xhr.responseText) {
                    message = xhr.responseText;
                }

                showDeleteResult("Deletion Failed", message);
            });
        });
        
        $("#loadAllCheck").change(function () {
            requestRepopulateTable();
        });
        
        $(function () {
            $("#groupSelect").change(function () {
                let date = new Date();
                date.setFullYear(date.getFullYear() + 2);
                
                const groupId = $("#groupSelect").val();
                
                document.cookie = "@cookieName" + "=" + groupId + "; path=/; expires=" +  date.toUTCString() + "; samesite=strict";
                
                requestRepopulateTable();
            });
            
            $("#groupSelect").val("@defaultGroupId").change();
        });
    </script>
}
